# ─── Local dev environment ────────────────────────────────────────────────────
# Copy to .env and adjust.
# Never commit .env — it's in .gitignore.

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ── Postgres ──────────────────────────────────────────────────────────────────
# When running locally (not in Docker): start postgres manually or via docker compose postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ansrmart
DB_USER=ansrmart
DB_PASSWORD=localdevpassword

# ── JWT ───────────────────────────────────────────────────────────────────────
# Change this to a random 32+ char string in production
JWT_SECRET=local-jwt-secret-dev-only-change-in-prod

# ── AWS / Floci ───────────────────────────────────────────────────────────────
# Point to Floci for local dev; leave blank in production to hit real AWS
AWS_ENDPOINT_URL=http://localhost:4566
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── Secrets Manager (optional — used in production) ───────────────────────────
# If set, DB_PASSWORD and JWT_SECRET are ignored and secrets are fetched from AWS
# Leave blank for local dev (DB_PASSWORD and JWT_SECRET are used directly)
DB_SECRET_NAME=
JWT_SECRET_NAME=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for rate-limiting and caching. Falls back gracefully if unavailable.
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origin of the web frontend; used to set CORS allow-list
WEB_ORIGIN=http://localhost:8080

# ── Database SSL (AWS RDS) ────────────────────────────────────────────────────
# Local Docker Postgres does not use TLS. AWS RDS requires it — set DB_SSL=true.
DB_SSL=false

# ── CDN / images ──────────────────────────────────────────────────────────────
# Product images live in S3 (Floci locally, S3/CloudFront in prod).
# Pipeline:  node scripts/extract-images.js   (iconic-images → data/image/)
#            node scripts/upload-images-to-s3.js  (data/image/ → s3://ansrmart-images/images/)
# nginx proxies /images/ → S3, so the browser stays same-origin (see apps/web/nginx.conf).
# To bypass the nginx proxy and hit a CDN directly, set VITE_IMAGE_BASE_URL at build time.
IMAGE_BASE_URL=/images
# VITE_IMAGE_BASE_URL=https://cdn.ansrmart.io/images

# ── Notifications ─────────────────────────────────────────────────────────────
# NOTIFICATIONS_ENABLED=false     set to true to send order SMS/events
# NOTIFICATIONS_PROVIDER=log      options: log | sns | twilio
# SNS_ORDER_TOPIC_ARN=            arn:aws:sns:us-east-1:000000000000:ansrmart-order-events
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_PROVIDER=log
SNS_ORDER_TOPIC_ARN=
